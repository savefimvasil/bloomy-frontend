{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/canvas/*": ["../bloomy-packages/planner/src/canvas/*"],
      "@/garden/*": ["../bloomy-packages/planner/src/garden/*"],
      "@/sidebar/*": ["../bloomy-packages/planner/src/sidebar/*"],
      "@/ui/*": ["../bloomy-packages/planner/src/ui/*"],
      "@/lib/constants": ["../bloomy-packages/planner/src/lib/constants"],
      "@/lib/types": ["../bloomy-packages/planner/src/lib/types"],
      "@/lib/geometry": ["../bloomy-packages/planner/src/lib/geometry"],
      "@/lib/labels": ["../bloomy-packages/planner/src/lib/labels"],
      "@/lib/hooks": ["../bloomy-packages/planner/src/lib/hooks"],
      "@/lib/optimal-patterns": ["../bloomy-packages/planner/src/lib/optimal-patterns"],
      "@/lib/config": ["../bloomy-packages/planner/src/lib/config"],
      "@/lib/config/*": ["../bloomy-packages/planner/src/lib/config/*"],
      "@/*": ["./*"],
      "@bloomy/bloomy-planner": ["../bloomy-packages/planner/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
